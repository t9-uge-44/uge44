---
import CTA1 from "./CTA1.astro";

interface Slide {
  title: string;
  text: string;
  image: string;
  href?: string;
}

interface Props {
  slides: Slide[];
  titel?: string;
}

const { slides, titel } = Astro.props;
---

<section class="karrusel-wrapper">
  {titel && <h2 class="karrusel-titel">{titel}</h2>}

  <div class="karrusel">
    <button class="pil venstre desktop-pil" id="forrige-desktop" aria-label="Forrige">&#8249;</button>

    <div class="slides-container">
      {
        slides.map((slide, i) => (
          <div class={`slide ${i === 0 ? "aktiv" : ""}`} data-index={i}>
            <div class="billede">
              <img src={slide.image} alt={slide.title} />
            </div>
            <div class="tekst">
              <h3>{slide.title}</h3>
              <p>{slide.text}</p>
              {slide.href && (
                <div class="cta-wrapper">
                  <CTA1 text="Se mere" href={slide.href} />
                </div>
              )}
            </div>
          </div>
        ))
      }
    </div>

    <button class="pil højre desktop-pil" id="næste-desktop" aria-label="Næste">&#8250;</button>
  </div>

  <div class="mobil-navigation">
    <button class="pil" id="forrige-mobil" aria-label="Forrige">&#8249;</button>
    <div class="dots">
      {slides.map((_, i) => <button class={`dot ${i === 0 ? "aktiv" : ""}`} data-i={i} aria-label={`Gå til slide ${i + 1}`} />)}
    </div>
    <button class="pil" id="næste-mobil" aria-label="Næste">&#8250;</button>
  </div>

  <div class="desktop-dots">
    {slides.map((_, i) => <button class={`dot ${i === 0 ? "aktiv" : ""}`} data-i={i} aria-label={`Gå til slide ${i + 1}`} />)}
  </div>
</section>

<style>
  .karrusel-wrapper {
    padding: 2rem 0 3rem;
    text-align: center;
  }

  .karrusel-titel {
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: 2rem;
  }

  .karrusel {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f5c5ae;
    border-radius: 60% 60% 60% 60% / 20% 20% 20% 20%;
    min-height: 420px;
  }

  .slides-container {
    flex: 1;
    overflow: hidden;
  }

  .slide {
    display: none;
    align-items: center;
    gap: 2rem;
  }

  .slide.aktiv {
    display: flex;
  }

  .tekst {
    flex: 1;
    text-align: left;
  }

  .tekst h3 {
    font-size: 1.4rem;
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .tekst p {
    font-size: 1rem;
    line-height: 1.7;
    color: #333;
    max-width: 70%;
  }

  .billede {
    flex: 1;
    display: flex;
    justify-content: center;
  }

  .billede img {
    width: 100%;
    max-width: 340px;
    border-radius: 16px;
    object-fit: cover;
  }

  .pil {
    background: #e56c45;
    color: white;
    border: none;
    border-radius: 50%;
    width: 56px;
    height: 56px;
    font-size: 3rem;
    cursor: pointer;
    flex-shrink: 0;
    transition: background 0.15s;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .pil:hover {
    background: #a8522a;
  }

  .desktop-dots {
    display: flex;
    justify-content: center;
    gap: 10px;
    margin-top: 1.25rem;
  }

  .dot {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: #d4b0a0;
    border: none;
    cursor: pointer;
    transition: background 0.15s;
  }

  .dot.aktiv {
    background: #e56c45;
  }

  .mobil-navigation {
    display: none;
  }

  .cta-wrapper {
    margin-top: 1.5rem;
  }

  @media (max-width: 800px) {
    .karrusel {
      border-radius: 24px;
      padding: 1.5rem 1.25rem 2rem;
      flex-direction: column;
      min-height: unset;
    }

    .desktop-pil,
    .desktop-dots {
      display: none;
    }

    .slide.aktiv {
      flex-direction: column;
    }

    .billede {
      width: 100%;
    }

    .billede img {
      max-width: 100%;
      border-radius: 12px;
    }

    .tekst {
      text-align: left;
      padding: 0 0.25rem;
    }

    .mobil-navigation {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 1rem;
      margin-top: 1.5rem;
    }

    .mobil-navigation .dots {
      display: flex;
      gap: 10px;
    }
  }
</style>

<script>
  const alleSlides = document.querySelectorAll(".slide");
  const allDots = document.querySelectorAll(".dot");
  let aktivSlide = 0;

  function getSynlige(): HTMLElement[] {
    return [...alleSlides].filter((s) => (s as HTMLElement).style.display !== "none") as HTMLElement[];
  }

  function opdaterDots() {
    const synlige = getSynlige();
    const aktivSlideEl = synlige[aktivSlide];
    const aktivIndex = Number((aktivSlideEl as HTMLElement)?.dataset.index);

    allDots.forEach((dot) => {
      const dotIndex = Number((dot as HTMLElement).dataset.i);
      // Skjul dots for skjulte slides
      const slideForDot = [...alleSlides].find((s) => Number((s as HTMLElement).dataset.index) === dotIndex);
      (dot as HTMLElement).style.display = (slideForDot as HTMLElement)?.style.display === "none" ? "none" : "";

      // Sæt aktiv kun på den aktuelle
      dot.classList.toggle("aktiv", dotIndex === aktivIndex);
    });
  }

  function visSlide(n: number) {
    const synlige = getSynlige();
    if (synlige.length === 0) return;

    synlige[aktivSlide]?.classList.remove("aktiv");
    aktivSlide = ((n % synlige.length) + synlige.length) % synlige.length;
    synlige[aktivSlide]?.classList.add("aktiv");

    opdaterDots();
  }

  // Kør opdaterDots ved start så kun relevante dots vises
  opdaterDots();

  document.getElementById("forrige-desktop")?.addEventListener("click", () => visSlide(aktivSlide - 1));
  document.getElementById("næste-desktop")?.addEventListener("click", () => visSlide(aktivSlide + 1));
  document.getElementById("forrige-mobil")?.addEventListener("click", () => visSlide(aktivSlide - 1));
  document.getElementById("næste-mobil")?.addEventListener("click", () => visSlide(aktivSlide + 1));

  allDots.forEach((dot) => {
    dot.addEventListener("click", () => {
      const synlige = getSynlige();
      const slideIndex = Number((dot as HTMLElement).dataset.i);
      const synligIndex = synlige.findIndex((s) => Number((s as HTMLElement).dataset.index) === slideIndex);
      if (synligIndex !== -1) visSlide(synligIndex);
    });
  });

  document.addEventListener("filtrer-opdater", () => opdaterDots());
</script>
