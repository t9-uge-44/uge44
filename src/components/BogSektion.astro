---
import "../styles/global.css";
interface Props {
  imageSrc?: string;
  imageAlt?: string;
  filmHref?: string;
  bogHref?: string;
}
import CTA2 from "../components/CTA2.astro";

const {
  imageSrc,
  imageAlt = "Illustration af computer med bøger og planter",
  filmHref = "#",
  bogHref = "#",
} = Astro.props;
---

<section class="fob-sektion">
  <!-- Blob baggrund venstre -->
  <div class="blob blob-left" aria-hidden="true">
    <svg viewBox="0 0 500 500" xmlns="http://www.w3.org/2000/svg">
      <path
        d="M250,30 C370,10 470,100 480,220 C490,340 400,450 270,460 C140,470 30,380 20,250 C10,120 130,50 250,30Z"
        fill="#f0a98a"></path>
    </svg>
  </div>

  <!-- Blob baggrund højre -->
  <div class="blob blob-right" aria-hidden="true">
    <svg viewBox="0 0 500 500" xmlns="http://www.w3.org/2000/svg">
      <path
        d="M260,40 C380,20 470,110 475,240 C480,370 390,460 255,455 C120,450 25,360 30,230 C35,100 140,60 260,40Z"
        fill="#f5c4b0"></path>
    </svg>
  </div>

  <div class="fob-inner">
    <!-- VENSTRE: Billede -->
    <div class="fob-billede">
      <img
        src="../../public/img/img-uge44/bogliste.webp"
        alt="bøger og planter"
      />
    </div>

    <!-- HØJRE: Tekst + knapper -->
    <div class="fob-tekst">
      <h2 class="fob-heading">Film- og bogliste</h2>
      <p class="fob-beskrivelse">
        Her kan I downloade en film- og bogliste med anbefalinger, som kan
        bruges til at hente inspiration til indhold og formidling i jeres event.
      </p>
      <div class="fob-knapper">
        <CTA2 text="Filmliste" filename="/download/filmliste.pdf" />
        <CTA2 text="Bogliste" filename="/download/bogliste.pdf" />
      </div>
    </div>
  </div>
</section>

<style>
  .fob-sektion {
    position: relative;
    overflow: hidden;
    padding: 60px 0;
  }

  /* BLOBS */
  .blob {
    position: absolute;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .blob-left {
    width: 520px;
    top: -20px;
    left: -80px;
    opacity: 0.6;
  }

  .blob-right {
    width: 480px;
    top: -40px;
    right: -100px;
    opacity: 0.5;
  }

  /* LAYOUT */
  .fob-inner {
    position: relative;
    z-index: 1;
    max-width: 1350px;
    margin: 0 auto;
    padding: 0 60px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }

  /* BILLEDE */
  .fob-billede {
    border-radius: 20px;
    aspect-ratio: 4 / 3;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    backdrop-filter: blur(4px);
    border: 1px solid rgba(255, 255, 255, 0.6);
    max-width: 80%;
  }

  .fob-billede img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: 20px;
  }

  .billede-placeholder {
    font-size: 13px;
    color: #b08070;
    font-style: italic;
  }

  /* TEKST */
  .fob-tekst {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .fob-heading {
    font-size: 2rem;
    margin: 0;
    line-height: 1.2;
  }

  .fob-beskrivelse {
    line-height: 1.7;
    margin: 0;
    max-width: 420px;
  }

  /* KNAPPER */
  .fob-knapper {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    margin-top: 8px;
  }

  /* Boble-hale under knappen */
  .btn-boble {
    position: absolute;
    bottom: -10px;
    left: 18px;
    width: 0;
    height: 0;
    border-left: 10px solid transparent;
    border-right: 6px solid transparent;
    border-top: 12px solid #c94f28;
    transition: border-top-color 0.2s ease;
  }

  .fob-btn:hover .btn-boble {
    border-top-color: #b03f1f;
  }

  /* RESPONSIV */
  @media (max-width: 768px) {
    .fob-inner {
      grid-template-columns: 1fr;
      gap: 32px;
      padding: 0 24px;
    }

    .blob-left {
      width: 320px;
      left: -60px;
    }
    .blob-right {
      width: 280px;
      right: -60px;
    }
  }
</style>
